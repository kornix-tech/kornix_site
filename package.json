{
  "name": "kornix-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check:production-bundle": "sh scripts/check-production-bundle-api-base.sh dist",
    "test:contract": "sh scripts/check-frontend-contract.sh && node scripts/check-profile-metric-coverage.mjs && node scripts/check-water-regime-critical-contract.mjs",
    "typecheck": "tsc -p tsconfig.json --pretty false && tsc -p tsconfig.node.json --pretty false"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.14",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.6.2",
    "vite": "^8.0.16"
  }
}
